---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const sorted = allArticles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const base = import.meta.env.BASE_URL;

// Running record across all resolved picks
let wins = 0, top5s = 0, top10s = 0, misses = 0;
sorted.forEach(article => {
  article.data.picks?.forEach(pick => {
    if (pick.result === 'pending') return;
    if (pick.result === 'win')    { wins++; top5s++; top10s++; }
    else if (pick.result === 'top5')  { top5s++; top10s++; }
    else if (pick.result === 'top10') { top10s++; }
    else if (pick.result === 'miss')  { misses++; }
  });
});
const totalResolved = wins + misses + (top10s - wins);

function resultLabel(result: string) {
  const map: Record<string, string> = {
    win: 'WIN', top5: 'TOP 5', top10: 'TOP 10', top20: 'TOP 20',
    miss: 'MISS', pending: 'PENDING',
  };
  return map[result] ?? result.toUpperCase();
}

function formatDate(d: Date | string) {
  const date = d instanceof Date ? d : new Date(String(d) + 'T12:00:00');
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

// Build the full picks timeline:
// Each article contributes two potential rows:
//   1. The tournament it covered (e.g. The Masters) — always show, even if no picks
//   2. The nextTournament picks it published (e.g. RBC Heritage) — only if picks exist
// De-duplicate so nextTournament rows don't double up when that event's own article publishes.

interface Row {
  label: string;
  date: string;
  course?: string;
  picks: typeof sorted[0]['data']['picks'];
  articleId: string;
  articleTitle: string;
  isInaugural: boolean;
}

const rows: Row[] = [];
const seenTournaments = new Set<string>();

// Process newest-first
for (const article of sorted) {
  const hasPicks = article.data.picks && article.data.picks.length > 0;

  // Row A: the nextTournament picks (if any)
  if (hasPicks && article.data.nextTournament) {
    const key = article.data.nextTournament.toLowerCase().trim();
    if (!seenTournaments.has(key)) {
      seenTournaments.add(key);
      rows.push({
        label: article.data.nextTournament,
        date: article.data.nextTournamentDate ?? '',
        course: article.data.nextTournamentCourse,
        picks: article.data.picks,
        articleId: article.id,
        articleTitle: article.data.title,
        isInaugural: false,
      });
    }
  }

  // Row B: the covered tournament itself — show if we haven't shown it yet
  const coveredKey = article.data.tournament.toLowerCase().trim();
  if (!seenTournaments.has(coveredKey)) {
    seenTournaments.add(coveredKey);
    rows.push({
      label: article.data.tournament,
      date: formatDate(article.data.date),
      course: article.data.course,
      picks: hasPicks ? undefined : undefined, // no picks FOR this tournament
      articleId: article.id,
      articleTitle: article.data.title,
      isInaugural: !hasPicks, // first issue — picks start next week
    });
  }
}
---

<BaseLayout title="Picks Record" description="Every pick, every week. Scored after each tournament concludes.">
  <div class="picks-page">

    <header class="page-header container">
      <p class="page-kicker">Track record</p>
      <h1 class="page-title">The Picks Board</h1>
      <p class="page-lead">
        Every pick, every week. Cross-referenced against actual results.
        No deleting the misses.
      </p>

      {totalResolved > 0 && (
        <div class="record-row">
          <div class="record-item">
            <span class="record-number record--win">{wins}</span>
            <span class="record-label">Wins</span>
          </div>
          <div class="record-item">
            <span class="record-number">{top5s}</span>
            <span class="record-label">Top 5s</span>
          </div>
          <div class="record-item">
            <span class="record-number">{top10s}</span>
            <span class="record-label">Top 10s</span>
          </div>
          <div class="record-item">
            <span class="record-number record--miss">{misses}</span>
            <span class="record-label">Misses</span>
          </div>
        </div>
      )}
    </header>

    <div class="weeks container">

      {rows.length === 0 && (
        <div class="empty">
          <p class="empty-title">First picks dropping soon.</p>
          <p class="empty-body">Picks publish Sunday evening after each tournament wraps.</p>
        </div>
      )}

      {rows.map(row => (
        <div class="week">
          <div class="week-header">
            <div class="week-header-left">
              <h2 class="week-name">{row.label}</h2>
              <div class="week-meta">
                {row.date && <span>{row.date}</span>}
                {row.course && <><span class="sep">·</span><span>{row.course}</span></>}
              </div>
            </div>
            <a href={`${base}/articles/${row.articleId}`} class="week-article-link">
              {row.isInaugural ? 'Read article →' : 'View article →'}
            </a>
          </div>

          {row.isInaugural ? (
            <p class="inaugural-note">Inaugural issue — picks begin the following week.</p>
          ) : row.picks && row.picks.length > 0 ? (
            <div class="picks-row">
              {row.picks.map((pick, i) => (
                <div class={`pick pick--${pick.result}`}>
                  <span class="pick-name">{pick.player}</span>
                  {pick.note
                    ? <span class="pick-note">{pick.note}</span>
                    : <span class={`pick-badge pick-badge--${pick.result}`}>{resultLabel(pick.result)}</span>
                  }
                </div>
              ))}
            </div>
          ) : null}
        </div>
      ))}

    </div>
  </div>
</BaseLayout>

<style>
.picks-page { padding-bottom: var(--spacing-xl); }

/* ── Header ── */
.page-header {
  padding: 4rem 0 3rem;
  border-bottom: 1px solid var(--color-border);
  margin-bottom: 0;
}

.page-kicker {
  font-size: 0.75rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: var(--color-accent);
  margin-bottom: 1rem;
}

.page-title {
  font-family: var(--font-serif);
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 700;
  letter-spacing: -0.03em;
  margin-bottom: 1rem;
  color: var(--color-text);
}

.page-lead {
  font-size: 1rem;
  color: var(--color-text-muted);
  max-width: 52ch;
  line-height: 1.7;
  margin-bottom: 2.5rem;
}

/* ── Record ── */
.record-row {
  display: flex;
  gap: 3rem;
}

.record-item {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}

.record-number {
  font-family: var(--font-serif);
  font-size: 2.25rem;
  font-weight: 700;
  line-height: 1;
  color: var(--color-text);
}

.record--win  { color: var(--color-accent); }
.record--miss { color: #c0392b; }

.record-label {
  font-size: 0.6875rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--color-text-muted);
}

/* ── Weeks ── */
.weeks {
  display: flex;
  flex-direction: column;
}

.week {
  padding: 2.5rem 0;
  border-bottom: 1px solid var(--color-border);
}

.week-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 1rem;
  margin-bottom: 1.5rem;
}

.week-header-left {
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
}

.week-name {
  font-family: var(--font-serif);
  font-size: 1.375rem;
  font-weight: 600;
  color: var(--color-text);
  letter-spacing: -0.02em;
  margin: 0;
}

.week-meta {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.8125rem;
  color: var(--color-text-muted);
}

.sep { opacity: 0.4; }

.week-article-link {
  font-size: 0.8125rem;
  color: var(--color-text-muted);
  text-decoration: none;
  white-space: nowrap;
  transition: color 0.2s;
  padding-top: 0.25rem;
}

.week-article-link:hover { color: var(--color-accent); }

/* ── Inaugural note ── */
.inaugural-note {
  font-size: 0.875rem;
  color: var(--color-text-muted);
  font-style: italic;
}

/* ── Pick chips ── */
.picks-row {
  display: flex;
  flex-wrap: wrap;
  gap: 0.625rem;
}

.pick {
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
  padding: 0.875rem 1.125rem;
  border: 1px solid var(--color-border);
  border-radius: 4px;
  background: var(--color-surface);
  min-width: 130px;
}

.pick--win     { border-color: var(--color-accent); background: var(--color-accent-light, #fef9f0); }
.pick--top5    { border-color: #7bc47b; background: #f4fbf4; }
.pick--top10   { border-color: #aed8b0; }
.pick--miss    { opacity: 0.5; }
.pick--pending { border-style: dashed; }

.pick-name {
  font-size: 0.9375rem;
  font-weight: 600;
  color: var(--color-text);
}

.pick-note {
  font-size: 0.75rem;
  color: var(--color-text-muted);
  font-style: normal;
}

.pick-badge {
  font-size: 0.6875rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  color: var(--color-text-muted);
}

.pick-badge--win    { color: var(--color-accent); }
.pick-badge--top5   { color: #2e7d32; }
.pick-badge--top10  { color: #558b2f; }
.pick-badge--miss   { color: #c0392b; }

/* ── Empty ── */
.empty { padding: 4rem 0; }
.empty-title {
  font-family: var(--font-serif);
  font-size: 1.5rem;
  font-weight: 600;
  margin-bottom: 0.5rem;
  color: var(--color-text);
}
.empty-body { font-size: 1rem; color: var(--color-text-muted); }

@media (max-width: 600px) {
  .record-row { gap: 1.5rem; flex-wrap: wrap; }
  .week-header { flex-direction: column; }
  .week-article-link { padding-top: 0; }
}
</style>
